# Frontend Environment Variables
# NOTE: The app frontend is served directly by the backend at http://localhost:8400.
# There is no separate frontend dev server in production — run `npm run build`
# and the backend serves dist/ automatically.
# For local development (npm run dev on port 5173), the vite proxy forwards
# /api → 8400 and /ws → 8400, so no extra config is needed.

VITE_APP_NAME=AdvanDEB Modeling Assistant
VITE_GOOGLE_CLIENT_ID=your-google-client-id

