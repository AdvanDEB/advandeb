[Unit]
Description=AdvanDEB Knowledge Builder API
After=network.target mongod.service

[Service]
Type=simple
User=adeb
Group=adeb
WorkingDirectory=/home/adeb/dev/advandeb/knowledge-builder/dev-server
EnvironmentFile=/home/adeb/dev/advandeb/knowledge-builder/dev-server/.env

ExecStart=/home/adeb/miniforge3/envs/advandeb/bin/uvicorn main:app \
    --host 0.0.0.0 \
    --port 8500 \
    --log-level info

Restart=always
RestartSec=10
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
