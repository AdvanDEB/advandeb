[Unit]
Description=AdvanDEB Modeling Assistant (FastAPI + Vue SPA)
After=network.target

[Service]
Type=simple
User=adeb
Group=adeb
WorkingDirectory=/home/adeb/dev/advandeb/app/backend

EnvironmentFile=/home/adeb/dev/advandeb/app/backend/.env

ExecStart=/home/adeb/miniforge3/envs/advandeb/bin/uvicorn app.main:app \
    --host 0.0.0.0 \
    --port 8400 \
    --log-level info

Restart=always
RestartSec=10

LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
